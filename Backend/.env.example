# ── Server ─────────────────────────────────────────────
PORT=5001
NODE_ENV=development

# ── Database (Supabase PostgreSQL) ─────────────────────
# Project Settings → Database → Connection string (URI)
# Use the "Transaction" pooler URL for serverless; "Session" for long-lived servers.
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ── App JWT (email/password auth) ──────────────────────
JWT_SECRET=your_super_secret_key_minimum_32_characters
JWT_EXPIRES_IN=7d

# ── Firebase Admin (token verification) ────────────────
# Option A: individual fields from Firebase service account JSON
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Option B: path to service account JSON file
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# Option C: full JSON string (useful for deployment platforms)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Admin seed — Firebase UID of the admin user (create in Firebase Console first)
ADMIN_FIREBASE_UID=

# ── Gemini AI ──────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Email (Resend) ─────────────────────────────────────
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=noreply@yourdomain.com

# ── Storage (Cloudflare R2 — production) ───────────────
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=qrcard-uploads
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ── Storage (MinIO — local dev) ────────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=qrcard-uploads

# ── App URLs ───────────────────────────────────────────
APP_BASE_URL=http://localhost:5001
CLIENT_BASE_URL=http://localhost:3000
